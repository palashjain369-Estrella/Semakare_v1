
{#
/**
 * @file
 * Default theme implementation for a value prop paragraph.
 * Backend Container Fields: field_headline, field_body, field_benefits
 */
#}
<section class="bg-surface-container-low py-24">
<div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
    <h2 class="text-4xl md:text-5xl font-bold leading-tight">
        {{ content.field_headline }}
    </h2>
    <div class="space-y-6">
        <div class="text-lg text-on-surface-variant leading-relaxed">
            {{ content.field_body }}
        </div>
        {# Renders bullet points if they exist #}
        <div class="grid grid-cols-2 gap-4">
            {{ content.field_benefits }}
        </div>
    </div>
</div>
</section>
