<!-- Hero Content (WHR Specific) -->
<section class="relative overflow-hidden py-16">
<div class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
<div class="z-10">
<span class="inline-block px-4 py-1.5 rounded-full bg-secondary-fixed text-on-secondary-fixed text-xs font-bold uppercase tracking-widest mb-6">Health Insights Tool</span>
<h2 class="font-headline text-5xl md:text-6xl font-extrabold tracking-tight text-on-surface leading-[1.1] mb-8">
                    Understanding Your <span class="bg-gradient-to-r from-[#6C5CE7] to-[#A29BFE] bg-clip-text text-transparent">Body Shape</span>
</h2>
<p class="text-xl text-on-surface-variant leading-relaxed mb-10 max-w-xl">
                    The Waist-to-Hip Ratio (WHR) is a quick way to see how your body stores fat and understand your metabolic health.
                </p>
<a class="inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-primary text-on-primary font-bold shadow-lg shadow-primary/20 hover:shadow-xl hover:translate-y-[-2px] transition-all" href="#calculator">
                    Measure Your Health
                    <span class="material-symbols-outlined">arrow_downward</span>
</a>
</div>
<div class="relative">
<div class="absolute -top-12 -left-12 w-64 h-64 bg-primary-fixed opacity-20 blur-3xl rounded-full"></div>
<div class="absolute -bottom-12 -right-12 w-64 h-64 bg-secondary-fixed opacity-20 blur-3xl rounded-full"></div>
<div class="relative rounded-xl overflow-hidden shadow-2xl">
<img class="w-full aspect-[4/3] object-cover" data-alt="Modern minimalist fitness studio setting with professional measuring tape and healthy lifestyle elements in soft morning light" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDSvUIQUY9gNPXoeaWUKYVeOcacuSDq6VBrN5BWbH6VrDQU4Tj0BYX2U_TyzM91jWEkFUr-zQkznw34wtmV38bV-AC4OYLDaiKquqTvZixXmPp5da_B73jsI-9vAoQ31jKQUlxxeuJN5iGGU2hgC8iGWWFIgjK4Yx9Jzx7uV2ft--8FJ-V-8CuN7FHoGSECuJmLHS3e2heoWr2oxMO73Bt44DMGykg_9LzfbHcB25zolnlsgCVlM7vSl4giMjVHcpgqwf-7zz6ArMcX"/>
</div>
</div>
</div>
