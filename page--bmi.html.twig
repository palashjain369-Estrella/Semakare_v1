<div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl mb-6">
<p class="font-mono text-xl text-center">BMI = kg/m²</p>
</div>
</div>
<p class="text-sm text-on-primary-container/80 leading-snug italic">
                        "A simple calculation that provides a starting point for meaningful health conversations."
                    </p>
</div>
